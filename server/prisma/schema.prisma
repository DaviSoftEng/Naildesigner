datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

// Configurações gerais (chave/valor). Ex.: bookingWindowDays, depositPercent, depositPixKey
model Setting {
  key   String @id
  value String
}

// category: unhas | sobrancelhas
model Service {
  id           Int                  @id @default(autoincrement())
  name         String
  price        Float
  duration     Int
  description  String
  category     String               @default("unhas")
  image        String               @default("")
  active       Boolean              @default(true)
  appointments AppointmentService[]
}

// status: confirmed | completed | no_show | cancelled
model Appointment {
  id            Int                  @id @default(autoincrement())
  clientName    String
  clientPhone   String
  date          String
  time          String
  status        String               @default("confirmed")
  notes         String               @default("")
  price         Float                @default(0)
  totalDuration Int                  @default(0)
  services      AppointmentService[]
  createdAt     DateTime             @default(now())
}

model AppointmentService {
  id            Int         @id @default(autoincrement())
  appointmentId Int
  serviceId     Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id])
}

// Cliente fixa: reserva permanente por dia da semana, com duração real do atendimento
model RecurringBlock {
  id         Int    @id @default(autoincrement())
  clientName String
  dayOfWeek  Int
  time       String
  duration   Int    @default(60)
  notes      String @default("")
}

// Horário de funcionamento por dia da semana (0=Dom ... 6=Sab).
// breakStart/breakEnd: pausa de almoço opcional, configurável por dia.
model BusinessHours {
  id         Int     @id @default(autoincrement())
  dayOfWeek  Int     @unique
  isOpen     Boolean @default(true)
  openTime   String  @default("09:00")
  closeTime  String  @default("19:00")
  breakStart String?
  breakEnd   String?
}

// Bloqueio de dia específico (férias, feriado, folga)
model DayBlock {
  id        Int     @id @default(autoincrement())
  date      String
  reason    String  @default("")
  startTime String?
  endTime   String?
}

// Portfólio de trabalhos exibido no site (gerenciado pelo painel)
model GalleryPhoto {
  id        Int      @id @default(autoincrement())
  image     String
  caption   String   @default("")
  category  String   @default("unhas")
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
