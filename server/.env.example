# Copie este arquivo para .env e preencha os valores
DATABASE_URL="file:./dev.db"

# Gere uma chave forte (>= 32 chars): node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="substitua-por-uma-chave-forte-de-pelo-menos-32-caracteres"

PORT=3001
# Host de bind. Use 127.0.0.1 se a API só deve ser acessada pelo proxy local.
HOST=0.0.0.0
CLIENT_URL=http://localhost:5173

# Credenciais da administradora inicial (usadas pelo seed / resetAdmin)
ADMIN_NAME="Nome da Admin"
ADMIN_EMAIL="admin"
ADMIN_PASSWORD="defina-uma-senha-forte"
